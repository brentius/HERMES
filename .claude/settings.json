{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(py:*)",
      "Bash(pip:*)",
      "Bash(pip install:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m pip:*)",
      "Bash(python -m hermes:*)",
      "Bash(hermes:*)",
      "Bash(uv:*)",
      "PowerShell(python:*)",
      "PowerShell(py:*)",
      "PowerShell(pip:*)",
      "PowerShell(pytest:*)",
      "PowerShell(hermes:*)",
      "PowerShell(uv:*)",
      "PowerShell(Get-ChildItem:*)",
      "PowerShell(Get-Content:*)",
      "PowerShell(Test-Path:*)"
    ]
  }
}
